{
  "name": "qa-automation-portfolio",
  "version": "1.0.0",
  "private": true,
  "description": "End-to-end QA automation portfolio covering UI, API, contract and performance testing.",
  "scripts": {
    "start": "node app/server.js",
    "typecheck": "tsc --noEmit",
    "test:ui": "playwright test",
    "test:ui:headed": "playwright test --headed",
    "test:api": "mvn -f api-tests/pom.xml test",
    "test:performance": "k6 run performance-tests/storefront-load.js",
    "report:allure": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@types/node": "24.10.1",
    "allure-commandline": "2.35.1",
    "allure-playwright": "3.4.2",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
